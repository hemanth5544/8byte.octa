{
  "name": "portfolio-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:seed": "pnpm --filter @portfolio/api db:seed",
    "vercel-build": "pnpm --filter @portfolio/api copy:wasm && pnpm --filter @portfolio/api build && pnpm --filter @portfolio/web build"
  },
  "dependencies": {
    "@vercel/node": "^5.3.21"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
